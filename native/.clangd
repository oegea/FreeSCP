# clangd config for the native port. The engine assumes 2-byte wchar_t and pulls the
# Embarcadero RTL shims from rtlcompat; without these flags the editor shows false errors
# on every header. Real builds use CMake (compile_commands.json) which already sets these.
CompileFlags:
  Add:
    - -std=c++17
    - -fshort-wchar
    - -Wno-unknown-pragmas
    - -I__FILE_DIR__/rtlcompat/include
    - -I__FILE_DIR__/../source/core
